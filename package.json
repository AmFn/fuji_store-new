{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "main": "src/main/main.cjs",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:3003 && cross-env NODE_ENV=development electron .\"",
    "dev": "vite --port=3003 --host=0.0.0.0",
    "build": "vite build",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.fuji.station",
    "productName": "Fuji Station",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.1.1",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "exifr": "^7.1.3",
    "exiftool-vendored": "^35.15.1",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "p-queue": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-virtualized-auto-sizer": "^1.0.25",
    "react-virtuoso": "^4.18.4",
    "react-window": "^1.8.10",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
